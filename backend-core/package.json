{
  "name": "@tindanzor/auth-server",
  "version": "2.3.0",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/mrtindanzor/auth-system"
  },
  "homepage": "https://github.com/mrtindanzor/auth-system",
  "bugs": {
    "url": "https://github.com/mrtindanzor/auth-system/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "biome check src/ && tsc --noEmit",
    "lint:fix": "biome check --write src/ && tsc --noEmit",
    "format": "biome check --write src/",
    "build": "tsc && tsc-alias --resolve-full-paths",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "jose": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/bcrypt": "^6.0.0",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3"
  }
}
